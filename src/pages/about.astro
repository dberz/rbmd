---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import SubscribeBlock from "@components/SubscribeBlock.astro";

const pressLogos = [
  { name: "Fast Company", src: "/images/press/BerzinMedia-01.svg" },
  { name: "Vogue", src: "/images/press/BerzinMedia-02.svg" },
  { name: "Women's Health", src: "/images/press/BerzinMedia-03.svg" },
  { name: "The New York Times", src: "/images/press/BerzinMedia-04.svg" },
  { name: "Goop", src: "/images/press/BerzinMedia-05.svg" },
];

const credentials = [
  { label: "Founder & CEO", detail: "Parsley Health" },
  { label: "MD", detail: "Columbia University" },
  { label: "Residency", detail: "Internal Medicine, Mount Sinai" },
  { label: "Tech Pioneer", detail: "World Economic Forum" },
  { label: "100 Most Innovative Women", detail: "Inc. Magazine" },
  { label: "Author", detail: "State Change (Simon Element)" },
];
---
<BaseLayout
  title="About - Robin Berzin MD"
  description="Robin Berzin, MD is the founder and CEO of Parsley Health, a Columbia-trained physician, and a leading voice in women's functional medicine and longevity."
  canonical="https://robinberzinmd.com/about/"
>
  <PageHero
    eyebrow="About"
    title="Robin Berzin, MD"
    description="A leading voice in women's functional medicine, longevity, and root-cause healthcare."
  />

  <section class="section">
    <div class="shell two-column bio-section">
      <div class="bio-copy">
        <p>
          Dr. Robin Berzin is the Founder and CEO of
          <a href="https://www.parsleyhealth.com/">Parsley Health</a>, the nation's
          leading holistic medical practice designed to help people overcome chronic
          conditions. She founded Parsley to address the rising tide of chronic disease
          in America through personalized holistic medicine that puts food, lifestyle,
          and proactive diagnostic testing on the prescription pad next to medications.
          Since founding Parsley in 2016, Dr. Berzin has seen 80% of patients improve or
          resolve their chronic conditions within their first year of care, demonstrating
          the life-changing value of making modern holistic medicine accessible to
          everyone, anywhere. Parsley is available online nationwide.
        </p>
        <p>
          Dr. Berzin attended medical school at Columbia University and trained in
          Internal Medicine at Mount Sinai Hospital in New York City. She has been
          recognized by the World Economic Forum as a Tech Pioneer, named one of the 100
          most innovative women in business by <em>Inc. Magazine</em>, and praised by
          <em>Fast Company</em> for founding one of the World's Most Innovative Companies.
          Her book, <a href="/book/"><em>State Change</em></a>, is published by Simon Element.
        </p>
      </div>
      <div class="bio-portrait">
        <img src="/images/robin/portrait-cream.jpg" alt="Robin Berzin MD" loading="eager" decoding="async" />
      </div>
    </div>
  </section>

  <section class="proof-strip" aria-label="Press">
    <div class="shell">
      <div class="press-logo-list">
        {pressLogos.map((logo) => (
          <span class="press-logo">
            <img src={logo.src} alt={logo.name} loading="lazy" decoding="async" />
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <span class="eyebrow">Background</span>
      <h2>Credentials &amp; recognition</h2>
      <div class="cred-grid">
        {credentials.map((item) => (
          <div class="cred-item">
            <span class="cred-label">{item.label}</span>
            <span class="cred-detail">{item.detail}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-subtle">
    <div class="shell">
      <blockquote class="pull-quote">
        <p>
          "Innovative, strategic, and wise, Dr. Berzin has created a gentle toolkit for
          reaching new levels of energy, clarity, and ease. Let her be your guide to a new
          baseline of well-being."
        </p>
        <cite>
          <span class="pull-quote-name">Erica Chidi</span>
          <span class="pull-quote-role">Co-founder &amp; CEO of LOOM</span>
        </cite>
      </blockquote>
    </div>
  </section>

  <section class="section">
    <div class="shell two-column">
      <div>
        <span class="eyebrow">Newsletter</span>
        <h2>Get Robin's weekly protocols.</h2>
        <p>
          Join 50,000+ readers for evidence-based guidance on women's longevity,
          hormones, metabolism, and the everyday health decisions that matter most.
        </p>
        <p>
          Robin is the founder of <a href="/parsley-health/">Parsley Health</a>, a
          root-cause medical practice with care available online, nationwide.
        </p>
      </div>
      <SubscribeBlock
        placement="about-bottom"
        eyebrow="Free protocol"
        title="Get My Ultimate Female Longevity Supplement Stack"
        description="A practical, evidence-based starting point for women who want to improve energy, metabolic health, and long-term resilience."
        buttonText="Get the free protocol"
      />
    </div>
  </section>
</BaseLayout>
