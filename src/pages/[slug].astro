---
import type { CollectionEntry } from "astro:content";
import { getCollection, getEntry } from "astro:content";
import SubscribeBlock from "@components/SubscribeBlock.astro";
import ArticleCard from "@components/ArticleCard.astro";
import GateBlock from "@components/GateBlock.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { articleUrl, categoryUrl, formatDate, plainText, tagUrl } from "@lib/content";
import { PINNED_RELATED_SLUG, gatedPosts, postCta, splitAtHeading, stripHeadingEmoji, stripKeepReading } from "@lib/optins";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.data.slug },
    props: { article },
  }));
}

type Props = {
  article: CollectionEntry<"articles">;
};

const { article } = Astro.props;
const slug = article.data.slug;
const description = article.data.seo?.description || article.data.excerpt || plainText(article.data.contentHtml).slice(0, 155);
const category = article.data.categories[0];

// Inline CTA copy: per-post override → lead-magnet default.
const cta = postCta[slug];
const articleLeadMagnetId = cta?.leadMagnet ?? "female-longevity-supplement-stack";
const articleLeadMagnet = await getEntry("leadMagnets", articleLeadMagnetId);

// Body: strip the legacy "Keep Reading" block (we render our own related row)
// and the decorative leading emoji from headings.
const bodyHtml = stripHeadingEmoji(stripKeepReading(article.data.contentHtml));

// Email gate for high-traffic posts.
const gate = gatedPosts[slug];
const split = gate ? splitAtHeading(bodyHtml, gate.markerHeading) : null;
const teaserHtml = split && split.locked ? split.teaser : bodyHtml;
const lockedHtml = split && split.locked ? split.locked : "";
const isGatedHere = Boolean(lockedHtml);

const readingMinutes = Math.max(
  1,
  Math.round(plainText(article.data.contentHtml).split(/\s+/).filter(Boolean).length / 200)
);

// Related posts: score by shared tags (x2) + shared category (x1); always pin
// the gated supplement-stack post as a recurring lead driver.
const allArticles = await getCollection("articles");
const tagSet = new Set(article.data.tags.map((t) => t.slug));
const catSet = new Set(article.data.categories.map((c) => c.slug));
function relatedScore(a: CollectionEntry<"articles">) {
  let score = 0;
  for (const t of a.data.tags) if (tagSet.has(t.slug)) score += 2;
  for (const c of a.data.categories) if (catSet.has(c.slug)) score += 1;
  return score;
}
const ranked = allArticles
  .filter((a) => a.data.slug !== slug)
  .sort((a, b) => relatedScore(b) - relatedScore(a) || b.data.date.getTime() - a.data.date.getTime());

const pinned = slug !== PINNED_RELATED_SLUG
  ? ranked.find((a) => a.data.slug === PINNED_RELATED_SLUG)
  : undefined;
const matches = ranked.filter((a) => a.data.slug !== PINNED_RELATED_SLUG);
const related = pinned ? [...matches.slice(0, 2), pinned] : matches.slice(0, 3);

const siteOrigin = Astro.site?.toString().replace(/\/$/, "") ?? "https://robinberzinmd.com";
const pageUrl = `${siteOrigin}${articleUrl(article.data.slug)}`;
const ogImage = article.data.image?.src;
const ogImageAbsolute = ogImage ? new URL(ogImage, `${siteOrigin}/`).toString() : undefined;

// Extract FAQ pairs from the article body for FAQPage schema (defensive).
function extractFaq(html: string) {
  const marker = /frequently asked questions/i;
  const markerMatch = html.search(marker);
  if (markerMatch === -1) return [] as { q: string; a: string }[];
  const tail = html.slice(markerMatch);
  const pairs: { q: string; a: string }[] = [];
  const re = /<h[34][^>]*>([\s\S]*?)<\/h[34]>\s*<p[^>]*>([\s\S]*?)<\/p>/gi;
  let m: RegExpExecArray | null;
  while ((m = re.exec(tail)) !== null) {
    const q = plainText(m[1]);
    const a = plainText(m[2]);
    if (q && a && q.includes("?")) pairs.push({ q, a });
  }
  return pairs;
}
const faqPairs = extractFaq(article.data.contentHtml);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.data.title,
  description,
  datePublished: article.data.date.toISOString(),
  dateModified: (article.data.modified ?? article.data.date).toISOString(),
  author: { "@type": "Person", name: article.data.author, url: `${siteOrigin}/about/` },
  publisher: {
    "@type": "Organization",
    name: "Robin Berzin MD",
    logo: { "@type": "ImageObject", url: `${siteOrigin}/logo/RobinBerzin-Logo-DarkBrown.png` },
  },
  mainEntityOfPage: pageUrl,
  ...(ogImageAbsolute ? { image: ogImageAbsolute } : {}),
  ...(category ? { articleSection: category.name } : {}),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteOrigin}/` },
    { "@type": "ListItem", position: 2, name: "Articles", item: `${siteOrigin}/articles/` },
    ...(category
      ? [{ "@type": "ListItem", position: 3, name: category.name, item: `${siteOrigin}${categoryUrl(category.slug)}` }]
      : []),
    { "@type": "ListItem", position: category ? 4 : 3, name: article.data.title, item: pageUrl },
  ],
};

const faqSchema =
  faqPairs.length >= 2
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqPairs.map((pair) => ({
          "@type": "Question",
          name: pair.q,
          acceptedAnswer: { "@type": "Answer", text: pair.a },
        })),
      }
    : null;

const jsonLd = [articleSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];
---
<BaseLayout
  title={`${article.data.title} | Robin Berzin MD`}
  description={description}
  canonical={`https://robinberzinmd.com${articleUrl(article.data.slug)}`}
  ogType="article"
  ogImage={ogImageAbsolute ?? "/images/robin/home.jpg"}
  jsonLd={jsonLd}
>
  <article>
    <header class="article-hero">
      <div class="article-header">
        {category && <a class="article-kicker" href={categoryUrl(category.slug)}>{category.name}</a>}
        <h1>{article.data.title}</h1>
        {article.data.excerpt && <p class="article-standfirst">{article.data.excerpt}</p>}
        <div class="article-byline">
          <img class="byline-avatar" src="/images/robin/home.jpg" alt="Robin Berzin MD" width="40" height="40" loading="eager" />
          <span class="byline-text">By {article.data.author}<span class="byline-sep">·</span>{formatDate(article.data.date)}<span class="byline-sep">·</span>{readingMinutes} min read</span>
        </div>
      </div>
      {article.data.image && (
        <div class="article-featured-image">
          <img
            src={article.data.image.src}
            alt={article.data.image.alt ?? article.data.title}
            loading="eager"
            decoding="async"
            onerror="this.closest('.article-featured-image').style.display='none'"
          />
        </div>
      )}
    </header>
    <div class="article-shell">
      <aside class="article-aside">
        <div class="article-rail-inner">
          <SubscribeBlock
            placement="article-rail"
            leadMagnet={articleLeadMagnet?.data.slug ?? articleLeadMagnetId}
            articleSlug={article.data.slug}
            category={category?.slug ?? ""}
            eyebrow={cta?.eyebrow ?? articleLeadMagnet?.data.eyebrow ?? "Free protocol"}
            title={cta?.title ?? articleLeadMagnet?.data.title ?? "Get Robin's free protocol"}
            description={cta?.description ?? articleLeadMagnet?.data.description ?? "Evidence-based guidance on women's longevity, hormones, and metabolism — straight to your inbox."}
            buttonText={cta?.buttonText ?? articleLeadMagnet?.data.buttonText ?? "Subscribe for free"}
          />
          <div class="side-panel">
            <span class="eyebrow">Topics</span>
            <div class="topic-row">
              {article.data.tags.map((tag) => <a class="tag tag-muted" href={tagUrl(tag.slug)}>{tag.name}</a>)}
            </div>
          </div>
        </div>
      </aside>
      <div class="article-main">
        <div class="article-body" set:html={teaserHtml} />
        {isGatedHere && gate && (
          <GateBlock
            slug={slug}
            eyebrow={gate.eyebrow}
            title={gate.title}
            description={gate.description}
            buttonText={gate.buttonText}
            leadMagnet={gate.leadMagnet ?? articleLeadMagnetId}
            category={category?.slug ?? ""}
            lockedHtml={lockedHtml}
          />
        )}
      </div>
    </div>
  </article>

  {related.length > 0 && (
    <section class="section section-subtle related-section">
      <div class="shell">
        <div class="related-head">
          <span class="eyebrow">Keep reading</span>
          <h2>Recommended for you</h2>
        </div>
        <div class="related-grid">
          {related.map((item) => <ArticleCard article={item} />)}
        </div>
        <div class="related-foot">
          <a class="btn btn-secondary" href="/articles/">View all articles</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
