---
import ArticleCard from "@components/ArticleCard.astro";
import PageHero from "@components/PageHero.astro";
import SubscribeBlock from "@components/SubscribeBlock.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getArticles, getPrimaryCategories } from "@lib/content";

const articles = await getArticles();
const categories = await getPrimaryCategories();
const startHere = articles.filter((article) =>
  [
    "normal-labs-fatigue-root-causes",
    "glp-1-hrt-hormone-connection",
    "perimenopause-symptoms-research",
  ].includes(article.data.slug)
);

const hubGradients: Record<string, string> = {
  "brain-mood-nervous-system": "linear-gradient(135deg, var(--color-lilac), var(--color-cream))",
  "fertility-parenting-robin-berzin-md": "linear-gradient(135deg, var(--color-beige), var(--color-off-white))",
  "longevity-metabolic-health": "linear-gradient(135deg, var(--color-dark-terracotta), var(--color-medium-brown))",
  "toxins-nutrition-modern-exposures": "linear-gradient(135deg, var(--color-medium-brown), var(--color-beige))",
  "womens-health-hormones": "linear-gradient(135deg, var(--color-lilac), var(--color-beige))",
};

const categoryHubs = categories.map((category) => {
  const inCategory = articles.filter((article) =>
    article.data.categories.some((c) => c.slug === category.data.slug)
  );
  return {
    slug: category.data.slug,
    name: category.data.name,
    count: inCategory.length,
    gradient: hubGradients[category.data.slug] ?? "linear-gradient(135deg, var(--color-lilac), var(--color-cream))",
  };
});
---
<BaseLayout
  title="Functional Medicine Articles | Robin Berzin MD"
  description="Evidence-based guidance on hormones, metabolism, longevity, fertility, nutrition, toxins, and nervous system health."
>
  <PageHero
    title="Functional Medicine Articles"
    description="Evidence-based guidance on hormones, metabolism, longevity, fertility, nutrition, toxins, and nervous system health."
  />

  {startHere.length > 0 && (
    <section class="section section-subtle">
      <div class="shell">
        <span class="eyebrow">Start Here</span>
        <div class="article-grid">
          {startHere.map((article) => <ArticleCard article={article} />)}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="shell">
      <div class="archive-tools">
        <div>
          <span class="eyebrow">Explore by topic</span>
          <h2>Category hubs</h2>
        </div>
      </div>
      <div class="hub-grid">
        {categoryHubs.map((hub) => (
          <a class="hub-card" href={`/category/${hub.slug}/`}>
            <span class="hub-illustration" style={`background:${hub.gradient}`} aria-hidden="true"></span>
            <h3>{hub.name}</h3>
            <p class="meta">{hub.count} {hub.count === 1 ? "article" : "articles"}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-subtle">
    <div class="shell">
      <div class="archive-tools">
        <div>
          <span class="eyebrow">Latest Articles</span>
          <h2>All articles</h2>
        </div>
      </div>
      <div class="filter-tabs" role="tablist" aria-label="Filter articles by topic">
        <button class="filter-tab is-active" data-filter="all" type="button">All</button>
        {categories.map((category) => (
          <button class="filter-tab" data-filter={category.data.slug} type="button">{category.data.name}</button>
        ))}
      </div>
      <div class="article-grid" id="articleGrid">
        {articles.map((article) => <ArticleCard article={article} />)}
      </div>
      <p class="filter-empty" id="filterEmpty" hidden>No articles in this topic yet.</p>
      <div class="load-more-row">
        <button class="btn btn-secondary" id="loadMore" type="button">Load more articles</button>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SubscribeBlock placement="articles-hub-inline" />
    </div>
  </section>

  <script is:inline>
    (function () {
      const grid = document.getElementById("articleGrid");
      if (!grid) return;
      const cards = Array.from(grid.children);
      const tabs = Array.from(document.querySelectorAll(".filter-tab"));
      const loadMore = document.getElementById("loadMore");
      const empty = document.getElementById("filterEmpty");
      const PAGE = 12;
      let filter = "all";
      let shown = PAGE;

      const matches = (card) => filter === "all" || card.getAttribute("data-category") === filter;

      function render() {
        let count = 0;
        cards.forEach((card) => {
          if (matches(card) && count < shown) {
            card.style.display = "";
            count++;
          } else {
            card.style.display = "none";
          }
        });
        const total = cards.filter(matches).length;
        if (loadMore) loadMore.style.display = shown < total ? "" : "none";
        if (empty) empty.hidden = total !== 0;
      }

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          tabs.forEach((t) => t.classList.remove("is-active"));
          tab.classList.add("is-active");
          filter = tab.getAttribute("data-filter");
          shown = PAGE;
          render();
        });
      });

      if (loadMore) {
        loadMore.addEventListener("click", () => {
          shown += PAGE;
          render();
        });
      }

      render();
    })();
  </script>
</BaseLayout>
