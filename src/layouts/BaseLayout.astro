---
import "../styles/global.css";
import NewsletterModal from "@components/NewsletterModal.astro";

type JsonLd = Record<string, unknown>;

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  bodyClass?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: JsonLd | JsonLd[];
};

const {
  title = "Robin Berzin MD",
  description = "Evidence-based guidance on women's functional medicine, longevity, hormones, metabolism, fertility, nutrition, and root-cause health.",
  canonical,
  noindex = false,
  bodyClass = "",
  ogImage = "/images/robin/home.jpg",
  ogType = "website",
  jsonLd,
} = Astro.props;

const ga4Id = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID;
const siteOrigin = Astro.site?.toString().replace(/\/$/, "") ?? "https://robinberzinmd.com";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, `${siteOrigin}/`).toString();
const ogImageUrl = new URL(ogImage, `${siteOrigin}/`).toString();

const SAME_AS = [
  "https://www.parsleyhealth.com/",
  "https://www.instagram.com/robinberzinmd",
  "https://www.linkedin.com/in/robin-berzin-md",
  "https://www.facebook.com/RobinBerzinMD",
];

const personSchema: JsonLd = {
  "@context": "https://schema.org",
  "@type": ["Person", "Physician"],
  "@id": `${siteOrigin}/#robin`,
  name: "Robin Berzin, MD",
  honorificSuffix: "MD",
  jobTitle: "Founder & CEO, Parsley Health",
  url: `${siteOrigin}/`,
  image: new URL("/images/robin/home.jpg", `${siteOrigin}/`).toString(),
  gender: "Female",
  description:
    "Columbia-trained physician and leading voice in women's functional medicine, longevity, and root-cause health.",
  knowsAbout: [
    "Functional medicine",
    "Women's health",
    "Longevity",
    "Perimenopause and menopause",
    "Hormone therapy",
    "Metabolic health",
    "GLP-1 medications",
    "Root-cause medicine",
  ],
  alumniOf: [
    { "@type": "CollegeOrUniversity", name: "Columbia University" },
    { "@type": "Hospital", name: "Mount Sinai Hospital" },
  ],
  worksFor: { "@type": "Organization", name: "Parsley Health", url: "https://www.parsleyhealth.com/" },
  sameAs: SAME_AS,
};

const organizationSchema: JsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteOrigin}/#org`,
  name: "Robin Berzin MD",
  url: `${siteOrigin}/`,
  logo: {
    "@type": "ImageObject",
    url: new URL("/logo/RobinBerzin-Logo-DarkBrown.png", `${siteOrigin}/`).toString(),
  },
  founder: { "@id": `${siteOrigin}/#robin` },
  sameAs: SAME_AS,
};

const websiteSchema: JsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteOrigin}/#website`,
  name: "Robin Berzin MD",
  url: `${siteOrigin}/`,
  publisher: { "@id": `${siteOrigin}/#org` },
};

const pageSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const schemas = [personSchema, organizationSchema, websiteSchema, ...pageSchemas];

const navItems = [
  { href: "/about/", label: "About" },
  { href: "/articles/", label: "Articles" },
  { href: "/media/", label: "Media" },
  { href: "/courses/", label: "Courses" },
];
const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath === href || currentPath.startsWith(href);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Robin Berzin MD" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#6F2E0F" />
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    {ga4Id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} is:inline></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${ga4Id}');`} />
      </>
    )}
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="shell nav-shell">
        <a class="brand" href="/" aria-label="Robin Berzin MD home">
          <img src="/logo/RobinBerzin-Logo-DarkBrown-T.png" alt="Robin Berzin MD" />
        </a>
        <nav class="desktop-nav" aria-label="Primary navigation">
          {navItems.map((item) => (
            <a href={item.href} class={isActive(item.href) ? "is-active" : undefined} aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
          ))}
        </nav>
        <a class="btn btn-primary nav-cta" href="/newsletter/">Get the newsletter</a>
        <button
          class="mobile-nav-toggle"
          type="button"
          aria-controls="mobile-nav"
          aria-expanded="false"
          aria-label="Open menu"
          data-mobile-nav-toggle
        >
          <span></span>
          <span></span>
        </button>
      </div>
      <nav class="mobile-nav-panel" id="mobile-nav" aria-label="Mobile navigation" hidden data-mobile-nav>
        {navItems.map((item) => (
          <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
        ))}
        <a href="/book/">Book</a>
        <a class="btn btn-primary" href="/newsletter/">Get the newsletter</a>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-grid">
        <div>
          <img class="footer-logo" src="/logo/RobinBerzin-Logo-OffWhite-T.png" alt="Robin Berzin MD" />
          <p>Functional medicine, longevity, and root-cause health for women.</p>
          <div class="footer-social">
            <a href="https://www.instagram.com/robinberzinmd" target="_blank" rel="noopener noreferrer" aria-label="Instagram">Instagram</a>
            <a href="https://www.linkedin.com/in/robin-berzin-md" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">LinkedIn</a>
            <a href="https://www.facebook.com/RobinBerzinMD" target="_blank" rel="noopener noreferrer" aria-label="Facebook">Facebook</a>
          </div>
        </div>
        <div>
          <h3>About</h3>
          <a href="/about/">Robin Berzin, MD</a>
          <a href="https://www.parsleyhealth.com/">Parsley Health</a>
          <a href="/media/">Media & speaking</a>
          <a href="/contact/">Contact</a>
        </div>
        <div>
          <h3>Resources</h3>
          <a href="/articles/">Articles</a>
          <a href="/courses/">Courses</a>
          <a href="/book/">State Change</a>
          <a href="/newsletter/">Newsletter</a>
        </div>
        <div>
          <h3>Newsletter</h3>
          <p>Get evidence-based protocols for women's longevity and functional medicine.</p>
          <form class="mini-form" data-subscribe-form>
            <input type="hidden" name="placement" value="footer" />
            <input type="hidden" name="leadMagnet" value="newsletter" />
            <label>
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>
            <button class="btn btn-primary" type="submit">Subscribe</button>
            <p class="form-status" data-form-status aria-live="polite"></p>
          </form>
        </div>
      </div>
      <div class="shell footer-disclaimer">
        <p>The content on this site is for educational purposes only and is not a substitute for professional medical advice, diagnosis, or treatment. Always consult a qualified healthcare provider with questions about your health.</p>
      </div>
      <div class="shell footer-bottom">
        <span>&copy; {new Date().getFullYear()} Robin Berzin MD</span>
        <a href="/terms-of-use/">Terms of Use</a>
        <a href="/disclaimer/">Disclaimer</a>
        <a href="https://nicesalt.com/" target="_blank" rel="noopener noreferrer">Site by NiceSalt</a>
      </div>
    </footer>
    <NewsletterModal />
    <script>
      import "../scripts/forms";
    </script>
    <script is:inline>
      const mobileToggle = document.querySelector("[data-mobile-nav-toggle]");
      const mobileNav = document.querySelector("[data-mobile-nav]");

      mobileToggle?.addEventListener("click", () => {
        const isOpen = mobileToggle.getAttribute("aria-expanded") === "true";
        mobileToggle.setAttribute("aria-expanded", String(!isOpen));
        mobileToggle.setAttribute("aria-label", isOpen ? "Open menu" : "Close menu");
        if (mobileNav) mobileNav.hidden = isOpen;
      });

      mobileNav?.addEventListener("click", (event) => {
        if (!(event.target instanceof HTMLAnchorElement)) return;
        mobileToggle?.setAttribute("aria-expanded", "false");
        mobileToggle?.setAttribute("aria-label", "Open menu");
        mobileNav.hidden = true;
      });

      const siteHeader = document.querySelector(".site-header");
      const onScroll = () => {
        if (!siteHeader) return;
        siteHeader.classList.toggle("is-scrolled", window.scrollY > 8);
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
    </script>
  </body>
</html>
