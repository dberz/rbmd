---
type Props = {
  eyebrow?: string;
  title: string;
  description?: string;
};

const { eyebrow, title, description } = Astro.props;
---
<section class="archive-header">
  <div class="shell">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1>{title}</h1>
    {description && <p>{description}</p>}
  </div>
</section>
