---
import type { CollectionEntry } from "astro:content";
import { articleUrl, formatDate } from "@lib/content";

type Props = {
  article: CollectionEntry<"articles">;
};

const { article } = Astro.props;
const category = article.data.categories[0];
const image = article.data.image;
---
<a class="article-card" href={articleUrl(article.data.slug)}>
  {image && <img src={image.src} alt={image.alt ?? article.data.title} loading="lazy" />}
  {category && <span class="tag">{category.name}</span>}
  <h3>{article.data.title}</h3>
  <p class="meta">{formatDate(article.data.date)}</p>
</a>
