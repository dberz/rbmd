# Beehiiv (server-side secrets — set in Vercel project env, never commit real values)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Inquiry/contact email delivery
INQUIRY_TO_EMAIL=
INQUIRY_FROM_EMAIL=website@robinberzinmd.com
RESEND_API_KEY=

# Google Analytics 4 — public (exposed to the browser). Format: G-XXXXXXXXXX
PUBLIC_GA4_MEASUREMENT_ID=

# Ops alerting (optional) — get pinged when a lead-capture path fails instead of
# silently dropping leads. Falls back to INQUIRY_TO_EMAIL if OPS_ALERT_EMAIL unset.
OPS_ALERT_EMAIL=
OPS_ALERT_WEBHOOK_URL=
